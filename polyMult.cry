module PolyMult where
import Types
multPoly : DoublePoly -> DoublePoly -> DoublePoly
multPoly a b = sum [[a@x * b@y | x<-[0..p*2-1]] >> y | y<-[0..2*p-1]]

polyMul : Poly -> Poly -> Poly
polyMul a b = c where
    fa = a # (zero : Poly)
    fb = b # (zero : Poly)
    prod = multPoly fa fb

    wrap = [prod @ i | i<-[p..(2*p-1)]] # (zero : Poly)

    wrap2 = wrap + (wrap >> 1)
    c = [prod@i + wrap2@i | i<-[0..p-1]]
