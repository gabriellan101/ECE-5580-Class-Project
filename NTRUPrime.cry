// Group 9 Streamlined variant NTRU Prime Cryptol

module NTRUPrime where

/*
 * Parameters
 * p: 761 - ring
 * q: 4591 - Modulus
 * w: 286 - weight
 * tau: ? - rounding parameter
 */

type p = 761
q = 4591
type w = 286

type Zq = [13]
type Poly = [p]Zq

// Mod Arithmetic
modq : Zq -> Zq
modq x = x % q

// Poly utils
zeroPoly : Poly
zeroPoly = [0 | i <- [0 .. p-1]]

