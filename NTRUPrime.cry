// Group 9 Streamlined variant NTRU Prime Cryptol

module NTRUPrime where

/*
 * Parameters
 * p: 761 - ring
 * q: 4591 - Modulus
 * w: 286 - weight
 * tau: ? - rounding parameter
 */

type p = 761
q = 4591
type w = 286

// Coefficient Ring Zq
type Zq = [13]

modq : Zq -> Zq  //modulus operator
modq z = z % q

// Polynomial Ring - represented as vectors of length p
type Poly = [p]Zq

/////////////////
// Poly utils
/////////////////

// null value polynomial ring
zeroPoly : Poly
zeroPoly = [0 | i <- [0 .. p-1]]

// polynomial of the form a_0(input) x^0 + 0x^1 + 0x^2 + ... + 0x^760
// modq c because q is maximum value of coeff.
constPoly : Zq -> Poly
constPoly c = 
    [if i == 0 then modq c else 0 | i <- [0 .. p-1]]

// monomial of the form a_c * x^k
// input poly degree, then coeff
monomial : Integer -> Zq -> Poly
monomial k c = 
    [if i == k then modq c else 0 | i <- [0 .. p-1]]

// Polynomial x
x : Poly
x = monomial 1 1

// Polynomial addition
polyAdd : Poly -> Poly -> Poly // takes 2 poly inputs for one poly output
polyAdd a b =
    [modq (a@i + b@i) | i <- [0 .. p-1]]

// Poly. Subtraction
polySub : Poly -> Poly -> Poly
polySub a b =
    [modq (a@i - b@i) | i <- [0 .. p-1]]

// Poly. Multiplication
polyMul : Poly -> Poly -> Poly
polyMul a b = undefined

// Polynomial Inverse
polyInv : Poly -> Poly
polyInv f = undefined

