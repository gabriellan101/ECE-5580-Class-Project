type z3 = Z 3
type Poly = [n]Integer
type DoublePoly = [2*n]Integer


multPoly : DoublePoly -> DoublePoly -> DoublePoly
multPoly a b = sum [[a@x * b@y | x<-[0..n*2-1]] >> y | y<-[0..2*n-1]]
